generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED_LOST
}

enum DealStage {
  QUALIFIED
  DISCOVERY_SCHEDULED
  DISCOVERY_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum EngagementStage {
  DISCOVERY
  AUDIT
  AUTOMATION
  TESTING
  IMPLEMENTATION
  OPTIMIZATION
  COMPLETED
  PAUSED
}


enum EngagementStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  COMPLETED
  BLOCKED
}

enum DeliverableStatus {
  DRAFT
  IN_REVIEW
  DELIVERED
}

enum InvoiceStatus {
  DRAFT
  SENT
  OVERDUE
  PAID
}

enum AIJobStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
}

enum AIInsightSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DailyFocusStatus {
  NOT_STARTED
  ACTIVE
  SNOOZED
  COMPLETED
  CLOSED
}

enum DailyChecklistItemType {
  CEO_SCAN
  REVENUE_MOVE
  DELIVERY_MOVE
  CASH_MOVE
  STRATEGIC_MOVE
  PROPOSAL_TOUCH
  BLOCKER_CLEAR
  PROOF_CAPTURE
  CASH_REVIEW
  CONTENT_SEED
  END_OF_DAY_WRAP
}

enum ConsultStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  RESOLVED
  CLOSED
}

enum FinanceRecordType {
  INVOICE
  PAYMENT
  CREDIT
  REFUND
}

enum FinanceRecordStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum QualityCheckStatus {
  PENDING
  PASSED
  FAILED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExpansionOpportunityStatus {
  IDENTIFIED
  PROPOSED
  WON
  LOST
}

enum RenewalStatus {
  UPCOMING
  IN_NEGOTIATION
  RENEWED
  CHURNED
}

enum AutomationRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedLeads        Lead[]       @relation("LeadOwner")
  ownedDeals        Deal[]       @relation("DealOwner")
  ownedEngagements  Engagement[] @relation("EngagementOwner")
  assignedTasks     Task[]       @relation("TaskOwner")
  createdEvents     Event[]      @relation("EventCreatedBy")
  ownedDeliverables Deliverable[] @relation("DeliverableOwner")
  issuedInvoices    Invoice[]    @relation("InvoiceOwner")
  aiJobs           AIJob[]      @relation("AIJobRequestedBy")
  aiInsights       AIInsight[] @relation("AIInsightCreatedBy")
  dailyFocusSessions DailyFocusSession[]
  reminderPreference UserReminderPreference?
  consults          Consult[]
  proposals         Proposal[]
  tickets           Ticket[]
  financeRecords    FinanceRecord[]
  qualityChecks     QualityCheck[]
  riskFlags         RiskFlag[]
  expansionOpportunities ExpansionOpportunity[] @relation("ExpansionOwner")
  renewalRecords    RenewalRecord[]
  automationRuns    AutomationRun[]
}

model Lead {
  id              String     @id @default(uuid())
  companyName     String
  contactName     String
  source          String?
  status          LeadStatus @default(NEW)
  ownerId         String
  nextStep        String?
  nextStepDueDate DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  owner User @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deals Deal[]

  @@index([ownerId])
}

model Deal {
  id              String    @id @default(uuid())
  leadId          String
  name            String
  stage           DealStage @default(QUALIFIED)
  value           Decimal?
  ownerId         String
  nextStep        String?
  nextStepDueDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  owner User @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  convertedClient Client?
  engagements     Engagement[]
  tasks           Task[]
  invoices        Invoice[]
  consults        Consult[]
  proposals       Proposal[]

  @@index([leadId])
  @@index([ownerId])
}

model Client {
  id                String   @id @default(uuid())
  name              String
  primaryContact    String?
  createdFromDealId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdFromDeal Deal?        @relation(fields: [createdFromDealId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  engagements     Engagement[]
  expansionOpportunities ExpansionOpportunity[]
  renewalRecords         RenewalRecord[]

  @@index([createdFromDealId])
}

model Engagement {
  id                   String          @id @default(uuid())
  clientId             String
  createdFromDealId    String?
  name                 String
  offerType            String?
  stage                EngagementStage  @default(DISCOVERY)
  status               EngagementStatus @default(ACTIVE)
  ownerId              String
  startDate            DateTime?
  targetEndDate        DateTime?
  nextMilestone        String?
  nextMilestoneDueDate DateTime?
  progressPercent      Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdFromDeal Deal? @relation(fields: [createdFromDealId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  owner User @relation("EngagementOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  tasks        Task[]
  deliverables Deliverable[]
  invoices     Invoice[]
  financeRecords FinanceRecord[]
  tickets      Ticket[]
  qualityChecks QualityCheck[]
  riskFlags    RiskFlag[]

  @@index([clientId])
  @@index([createdFromDealId])
  @@index([ownerId])
}

model Task {
  id           String     @id @default(uuid())
  title        String
  status       TaskStatus @default(NOT_STARTED)
  ownerId      String
  dealId       String?
  engagementId String?
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner      User        @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deal       Deal?       @relation(fields: [dealId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  engagement Engagement? @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([ownerId])
  @@index([dealId])
  @@index([engagementId])
}

model Event {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  eventType   String
  description String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByUser User @relation("EventCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([createdBy])
}

model Deliverable {
  id           String            @id @default(uuid())
  engagementId String
  name         String
  status       DeliverableStatus @default(DRAFT)
  ownerId      String
  dueDate      DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner      User       @relation("DeliverableOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([engagementId])
  @@index([ownerId])
}

model Invoice {
  id           String        @id @default(uuid())
  invoiceNumber String?
  amount       Decimal
  status       InvoiceStatus @default(DRAFT)
  dueDate      DateTime?
  paidAt       DateTime?
  ownerId      String
  dealId       String?
  engagementId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  owner      User        @relation("InvoiceOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deal       Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  engagement Engagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([ownerId])
  @@index([dealId])
  @@index([engagementId])
}


model AIJob {
  id           String      @id @default(uuid())
  type         String
  status       AIJobStatus @default(QUEUED)
  entityType   String
  entityId     String
  inputPayload Json
  outputPayload Json?
  errorMessage String?
  requestedBy  String
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  requestedByUser User @relation("AIJobRequestedBy", fields: [requestedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([requestedBy])
  @@index([entityType, entityId])
  @@index([status, createdAt])
}


model AIInsight {
  id             String            @id @default(uuid())
  entityType     String
  entityId       String
  summary        String
  recommendation String
  severity       AIInsightSeverity
  createdBy      String
  createdAt      DateTime          @default(now())

  createdByUser User @relation("AIInsightCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([createdBy])
  @@index([entityType, entityId])
  @@index([severity, createdAt])
}


model DailyFocusSession {
  id                 String           @id @default(uuid())
  userId             String
  sessionDate        DateTime
  status             DailyFocusStatus @default(NOT_STARTED)
  revenueFocusText   String
  deliveryFocusText  String
  cashFocusText      String
  strategicFocusText String?
  startedAt          DateTime?
  completedAt        DateTime?
  wrapUpCompletedAt  DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items DailyChecklistItem[]

  @@unique([userId, sessionDate])
  @@index([userId, sessionDate])
  @@index([status, sessionDate])
}

model DailyChecklistItem {
  id                  String                @id @default(uuid())
  dailyFocusSessionId String
  type                DailyChecklistItemType
  label               String
  isCompleted         Boolean               @default(false)
  completedAt         DateTime?
  linkedEntityType    String?
  linkedEntityId      String?
  sortOrder           Int
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  session DailyFocusSession @relation(fields: [dailyFocusSessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([dailyFocusSessionId, sortOrder])
  @@index([linkedEntityType, linkedEntityId])
}

model UserReminderPreference {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  startOfDayReminderEnabled Boolean  @default(true)
  middayReminderEnabled     Boolean  @default(true)
  endOfDayReminderEnabled   Boolean  @default(true)
  reminderChannelInApp      Boolean  @default(true)
  reminderChannelEmail      Boolean  @default(false)
  firstReminderTime         String?
  middayReminderTime        String?
  endOfDayReminderTime      String?
  snoozeMinutesDefault      Int      @default(30)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}


model Consult {
  id           String       @id @default(uuid())
  dealId        String
  ownerId       String
  scheduledFor  DateTime?
  status        ConsultStatus @default(SCHEDULED)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  deal          Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  proposals     Proposal[]

  @@index([dealId])
  @@index([ownerId, scheduledFor])
}

model Proposal {
  id           String         @id @default(uuid())
  dealId        String
  consultId     String?
  ownerId       String
  title         String
  status        ProposalStatus @default(DRAFT)
  sentAt        DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  deal          Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  consult       Consult?      @relation(fields: [consultId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([dealId])
  @@index([consultId])
  @@index([ownerId, status])
}

model Ticket {
  id           String       @id @default(uuid())
  engagementId  String
  ownerId       String
  title         String
  status        TicketStatus @default(OPEN)
  dueDate       DateTime?
  blockedReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  engagement    Engagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([engagementId, status])
  @@index([ownerId, dueDate])
}

model FinanceRecord {
  id            String             @id @default(uuid())
  engagementId   String
  ownerId        String
  type           FinanceRecordType
  amount         Decimal
  status         FinanceRecordStatus
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  engagement     Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([engagementId, status])
  @@index([ownerId])
}

model QualityCheck {
  id            String             @id @default(uuid())
  engagementId   String
  ownerId        String
  status         QualityCheckStatus @default(PENDING)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  engagement     Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([engagementId, status])
  @@index([ownerId])
}

model RiskFlag {
  id            String       @id @default(uuid())
  engagementId   String
  ownerId        String
  severity       RiskSeverity
  description    String
  isResolved     Boolean      @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  engagement     Engagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner          User         @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([engagementId, severity])
  @@index([isResolved, severity])
}

model ExpansionOpportunity {
  id            String                     @id @default(uuid())
  clientId       String
  ownerId        String
  title          String
  status         ExpansionOpportunityStatus @default(IDENTIFIED)
  estimatedValue Decimal?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  client         Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner          User                       @relation("ExpansionOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clientId, status])
  @@index([ownerId])
}

model RenewalRecord {
  id            String        @id @default(uuid())
  clientId       String
  ownerId        String
  status         RenewalStatus @default(UPCOMING)
  renewalDate    DateTime
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner          User          @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clientId, renewalDate])
  @@index([ownerId, status])
}

model AutomationRun {
  id            String               @id @default(uuid())
  name          String
  status        AutomationRunStatus  @default(QUEUED)
  entityType    String
  entityId      String
  inputPayload  Json
  outputPayload Json?
  errorMessage  String?
  requestedBy   String
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  requester     User @relation(fields: [requestedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([requestedBy])
  @@index([entityType, entityId])
  @@index([status, createdAt])
}
