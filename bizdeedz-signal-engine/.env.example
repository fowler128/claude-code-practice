# =============================================================
# BizDeedz Signal Engine — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================

# -----------------------------------------
# Email Recipients
# -----------------------------------------
EMAIL_PRIMARY=tureasimpson@gmail.com
EMAIL_SECONDARY=info@bizdeedz.com

# -----------------------------------------
# AI Providers
# -----------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------
# Google Sheets
# -----------------------------------------
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key including header/footer lines
# Wrap in double quotes and use \n for newlines
GOOGLE_PRIVATE_KEY=

# -----------------------------------------
# Apify (Reddit Scraper)
# -----------------------------------------
APIFY_API_TOKEN=

# -----------------------------------------
# Gmail (Email Sending)
# -----------------------------------------
GMAIL_USER=
# Use an App Password (not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# -----------------------------------------
# Optional: Model Overrides
# Defaults are set in config/models.json
# These env vars override config if set.
# -----------------------------------------
CLASSIFIER_MODEL=gpt-4o-mini
DIGEST_MODEL=claude-sonnet-4-6

# -----------------------------------------
# RSS Feeds
# Comma-separated list of active feed URLs.
# Or leave blank and edit config/rss-feeds.json + update the n8n RSS node directly.
# -----------------------------------------
RSS_FEED_URLS=https://www.artificiallawyer.com/feed/,https://www.lawsitesblog.com/feed,https://legaltechtrends.com/feed/,https://lawdroid.com/feed/,https://legalevolution.org/feed/

# -----------------------------------------
# Timezone
# -----------------------------------------
TIMEZONE=America/Chicago
