# Copy this file to .env and fill in values locally.
# Never commit your real .env.

# Required only for Apify actor runs (fallback discovery can run without it)
APIFY_TOKEN=

# Optional actor IDs by platform. If unset, discovery uses public fallback sources.
APIFY_ACTOR_YOUTUBE=
APIFY_ACTOR_TIKTOK=
APIFY_ACTOR_LINKEDIN=
